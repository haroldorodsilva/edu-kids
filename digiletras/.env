# Provedor de IA para o Gerador de Histórias (admin)
# Opções: anthropic | groq | openai | deepseek | gemini
# Padrão: anthropic
AI_PROVIDER=groq

# ── Chaves de API (configure apenas a do provedor escolhido) ──────────────────

# Anthropic Claude (pago — claude-haiku é muito barato)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Groq (GRATUITO — llama-3.1-8b, excelente para histórias curtas)
# https://console.groq.com/
GROQ_API_KEY=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

# Google Gemini (GRATUITO com limites — gemini-1.5-flash)
# https://aistudio.google.com/
GEMINI_API_KEY=

# OpenAI (pago — gpt-4o-mini é muito barato)
# https://platform.openai.com/
OPENAI_API_KEY=

# DeepSeek (muito barato — deepseek-chat)
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=
